HERMES_DB_PATH=./data/hermes.sqlite
HERMES_PORT=3000
# In production behind HTTPS, set this to true so cookies are marked Secure.
# In local dev (http://localhost) keep it false.
HERMES_COOKIE_SECURE=false

# CSRF token signing secret for cookie-authenticated mutations.
# Hermes uses a dev fallback if unset; set a strong random value in production.
HERMES_CSRF_SECRET=change-me

# Storage backend. Settings and app data live in SQLite; S3 stores/restores the SQLite snapshot.
HERMES_STORAGE_BACKEND=s3
HERMES_S3_BUCKET=hermes-storage
HERMES_S3_REGION=eu-central-2
HERMES_S3_ENDPOINT=https://s3.eu-central-2.wasabisys.com
HERMES_S3_CREDS_FILE=./s3.creds
HERMES_S3_DB_KEY=hermes.sqlite
HERMES_S3_RESTORE_MODE=if-missing

# Used once during bootstrap or whenever the main admin should be ensured.
# Login uses HERMES_ADMIN_USERNAME; the phone number remains profile data only.
HERMES_ADMIN_PHONE=+491700000000
HERMES_ADMIN_USERNAME=admin
HERMES_ADMIN_EMAIL=admin@example.test

# Mail delivery for login codes. Use "console" only for local development.
HERMES_MAIL_MODE=smtp
HERMES_MAIL_FROM=Hermes <hermes@example.test>
HERMES_SMTP_HOST=smtp.example.test
HERMES_SMTP_PORT=587
HERMES_SMTP_SECURE=false
HERMES_SMTP_SECURITY=starttls
HERMES_SMTP_USER=
HERMES_SMTP_PASSWORD=

# Web Push. Generate with: npx web-push generate-vapid-keys
HERMES_VAPID_SUBJECT=mailto:admin@example.test
HERMES_VAPID_PUBLIC_KEY=
HERMES_VAPID_PRIVATE_KEY=

# Optional local test override. Do not set this in production.
# HERMES_DEV_LOGIN_CODE=123456
