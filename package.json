{
  "name": "hermes",
  "version": "0.5.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build && npm run build:server",
    "build:server": "esbuild src/server/index.ts src/server/db/bootstrap-admin.ts src/server/db/migrate.ts --bundle --platform=node --format=esm --packages=external --outdir=dist-server && mkdir -p dist-server/migrations dist-server/db/migrations && cp src/server/db/migrations/*.sql dist-server/migrations/ && cp src/server/db/migrations/*.sql dist-server/db/migrations/",
    "db:bootstrap-admin": "tsx src/server/db/bootstrap-admin.ts",
    "db:migrate": "node dist-server/db/migrate.js",
    "db:migrate:dev": "tsx src/server/db/migrate.ts",
    "preview": "vite preview --host 0.0.0.0",
    "server": "tsx src/server/index.ts",
    "start": "node dist-server/index.js",
    "start:bootstrap-admin": "node dist-server/db/bootstrap-admin.js",
    "test": "vitest run src",
    "test:e2e": "npm run build && playwright test",
    "verify": "npm test && npm run build && npm audit --omit=dev",
    "verify:ci": "npm ci && npm test && npm run build && npm audit --omit=dev",
    "docker:build": "docker build --platform linux/amd64 -t hermes:local .",
    "verify:push": "npm run verify:ci && npm run docker:build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "better-sqlite3": "^12.9.0",
    "cookie-parser": "^1.4.7",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "nodemailer": "^8.0.5",
    "qrcode-generator": "^1.4.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^5.1.1",
    "esbuild": "^0.28.0",
    "jsdom": "^29.0.2",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.1.4"
  }
}
